{
  "name": "fx-example",
  "version": "1.0.0",
  "private": true,
  "description": "Example project showing how to use @fancoolo/fx",
  "scripts": {
    "build": "esbuild src/animations.js --bundle --minify --outfile=dist/animations.min.js",
    "build:dev": "esbuild src/animations.js --bundle --sourcemap --outfile=dist/animations.js",
    "watch": "esbuild src/animations.js --bundle --sourcemap --outfile=dist/animations.js --watch"
  },
  "dependencies": {
    "@fancoolo/fx": "file:.."
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
